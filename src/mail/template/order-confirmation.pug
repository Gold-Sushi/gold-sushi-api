//- ============================================================
//- Order confirmation email.
//- Locals: brand, subject, preheader, firstName,
//-         order { number, items[{ name, quantity, price, lineTotal }],
//-                 total, currency, deliveryLabel, address, phone }
//- ============================================================
extends layouts/base.pug

block content
  h1(style="margin:0 0 16px 0; font-family:Arial, sans-serif; font-size:22px; line-height:28px; color:#171a1b; text-align:center;")
    | Замовлення підтверджено ✅

  p(style="margin:0 0 8px 0; font-family:Arial, sans-serif; font-size:16px; line-height:24px; color:#171a1b; text-align:center;")
    | Добрий день#{firstName ? ', ' + firstName : ''}!

  p(style="margin:0 0 20px 0; font-family:Arial, sans-serif; font-size:16px; line-height:24px; color:#171a1b; text-align:center;")
    | Дякуємо за замовлення у закладі #[strong= brand.name]. Щойно воно буде готове,
    | його можна буде відстежувати на сайті.

  if order && order.number
    p(style="margin:0 0 16px 0; font-family:Arial, sans-serif; font-size:14px; line-height:20px; color:#546e7a; text-align:center;")
      | Замовлення №
      strong(style="color:#171a1b;")= order.number

  //- Itemized order summary
  table(role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 16px 0; border:1px solid #eceff1; border-radius:8px;")
    thead
      tr
        th(align="left" style="padding:12px 16px; font-family:Arial, sans-serif; font-size:12px; line-height:16px; color:#90a4ae; text-transform:uppercase; border-bottom:1px solid #eceff1;") Страва
        th(align="center" style="padding:12px 8px; font-family:Arial, sans-serif; font-size:12px; line-height:16px; color:#90a4ae; text-transform:uppercase; border-bottom:1px solid #eceff1;") К-сть
        th(align="right" style="padding:12px 16px; font-family:Arial, sans-serif; font-size:12px; line-height:16px; color:#90a4ae; text-transform:uppercase; border-bottom:1px solid #eceff1;") Сума
    tbody
      each item in (order && order.items) || []
        tr
          td(align="left" style="padding:12px 16px; border-bottom:1px solid #f5f7f8;")
            table(role="presentation" cellpadding="0" cellspacing="0" border="0")
              tr
                if item.image
                  td(style="padding:0 12px 0 0;" valign="middle")
                    img(src=item.image width="48" height="48" alt=item.name style="display:block; width:48px; height:48px; border:0; border-radius:6px; object-fit:cover;")
                td(valign="middle" style="font-family:Arial, sans-serif; font-size:14px; line-height:20px; color:#171a1b;")= item.name
          td(align="center" style="padding:12px 8px; font-family:Arial, sans-serif; font-size:14px; line-height:20px; color:#546e7a; border-bottom:1px solid #f5f7f8;")= item.quantity
          td(align="right" style="padding:12px 16px; font-family:Arial, sans-serif; font-size:14px; line-height:20px; color:#171a1b; border-bottom:1px solid #f5f7f8; white-space:nowrap;")= `${item.lineTotal} ${order.currency}`
    tfoot
      tr
        td(colspan="2" align="right" style="padding:14px 16px; font-family:Arial, sans-serif; font-size:15px; font-weight:bold; line-height:20px; color:#171a1b;") Разом
        td(align="right" style="padding:14px 16px; font-family:Arial, sans-serif; font-size:15px; font-weight:bold; line-height:20px; color:#171a1b; white-space:nowrap;")= `${order && order.total} ${order && order.currency}`

  //- Delivery details
  if order && (order.deliveryLabel || order.address || order.phone)
    table(role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 8px 0;")
      if order.deliveryLabel
        tr
          td(style="padding:4px 0; font-family:Arial, sans-serif; font-size:14px; line-height:20px; color:#546e7a;")
            strong(style="color:#171a1b;") Спосіб отримання:
            |  #{order.deliveryLabel}
      if order.address
        tr
          td(style="padding:4px 0; font-family:Arial, sans-serif; font-size:14px; line-height:20px; color:#546e7a;")
            strong(style="color:#171a1b;") Адреса:
            |  #{order.address}
      if order.phone
        tr
          td(style="padding:4px 0; font-family:Arial, sans-serif; font-size:14px; line-height:20px; color:#546e7a;")
            strong(style="color:#171a1b;") Телефон:
            |  #{order.phone}

  p(style="margin:20px 0 0 0; font-family:Arial, sans-serif; font-size:14px; line-height:22px; color:#546e7a; text-align:center;")
    | Виникли питання? Телефонуйте
    |
    a(href=`tel:${brand.supportPhone.replace(/[^+0-9]/g, '')}` style="color:#{brand.primaryColor}; text-decoration:none;")= brand.supportPhone
    |  або пишіть на
    |
    a(href=`mailto:${brand.supportEmail}` style="color:#{brand.primaryColor}; text-decoration:none;")= brand.supportEmail
    | .


