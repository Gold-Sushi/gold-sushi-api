//- ============================================================
//- Reusable footer partial — dark, high-contrast band with brand,
//- Instagram CTA, social icons (with links) and contact / legal.
//- Expects: brand
//- ============================================================
table(role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#14202a" style="background-color:#14202a;")
  //- Brand line
  tr
    td(align="center" style="padding:32px 32px 4px 32px;")
      p(style="margin:0; font-family:Arial, sans-serif; font-size:18px; font-weight:bold; line-height:24px; color:#ffffff; letter-spacing:0.5px;")= brand.name
  tr
    td(align="center" style="padding:0 32px 18px 32px;")
      p(style="margin:0; font-family:Arial, sans-serif; font-size:13px; line-height:20px; color:#9fb3c8;")
        | Смачні роли та суші з доставкою

  //- Primary call to action (bulletproof button for Outlook via VML)
  tr
    td(align="center" style="padding:0 32px 22px 32px;")
      div
        | <!--[if mso]>
        | <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="#{brand.instagramUrl}" style="height:46px;v-text-anchor:middle;width:280px;" arcsize="14%" strokecolor="#{brand.primaryColor}" fillcolor="#{brand.primaryColor}">
        | <w:anchorlock/>
        | <center style="color:#ffffff;font-family:Arial,sans-serif;font-size:14px;font-weight:bold;">Слідкуйте за нами в Instagram</center>
        | </v:roundrect>
        | <![endif]-->
        a(href=brand.instagramUrl target="_blank" style="background-color:#{brand.primaryColor}; color:#ffffff; display:inline-block; font-family:Arial, sans-serif; font-size:14px; font-weight:bold; line-height:46px; text-align:center; text-decoration:none; width:280px; border-radius:8px; mso-hide:all;")
          | Слідкуйте за нами в Instagram

  //- Social icons (with links) — each icon sits in a rounded badge
  tr
    td(align="center" style="padding:0 32px 22px 32px;")
      table(role="presentation" cellpadding="0" cellspacing="0" border="0")
        tr
          each social in (brand.socials || [])
            td(align="center" valign="middle" width="44" height="44" bgcolor="#22303c" style="width:44px; height:44px; background-color:#22303c; border-radius:22px;")
              a(href=social.url target="_blank" style="display:inline-block; line-heig ht:44px;")
                img(src=social.icon width="20" height="20" alt=social.name style="display:inline-block; width:20px; height:20px; border:0; vertical-align:middle;")
            td(width="12" style="width:12px; font-size:0; line-height:0;") &nbsp;

  //- Divider
  tr
    td(style="padding:0 32px;")
      table(role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0")
        tr
          td(height="1" style="height:1px; line-height:1px; font-size:0; background-color:#2c3e4c;") &nbsp;

  //- Contact details
  tr
    td(align="center" style="padding:18px 32px 4px 32px;")
      p(style="margin:0; font-family:Arial, sans-serif; font-size:13px; line-height:22px; color:#c7d4df;")
        a(href=`tel:${brand.supportPhone.replace(/[^+0-9]/g, '')}` style="color:#ffffff; text-decoration:none; font-weight:bold;")= brand.supportPhone
        |  &nbsp;•&nbsp;
        a(href=`mailto:${brand.supportEmail}` style="color:#ffffff; text-decoration:none; font-weight:bold;")= brand.supportEmail

  //- Legal / copyright
  tr
    td(align="center" style="padding:6px 32px 30px 32px;")
      p(style="margin:0; font-family:Arial, sans-serif; font-size:12px; line-height:18px; color:#7e93a3;")
        | &copy; #{brand.year} #{brand.name}. Усі права захищені.
        br
        | Ви отримали цей лист, тому що скористались послугами нашого закладу.

