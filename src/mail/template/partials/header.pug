//- ============================================================
//- Reusable header partial — hero banner linking to the menu.
//- Expects: brand
//- ============================================================
table(role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0")
  tr
    td(align="center" style="padding:0;" bgcolor="#ffffff")
      a(href=brand.menuUrl target="_blank" style="display:block; text-decoration:none;")
        img(src=brand.bannerUrl width="600" alt=brand.name style="display:block; width:100%; max-width:600px; height:auto; border:0;")

