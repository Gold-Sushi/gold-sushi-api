# Application
FORTEND_URL=

# JWT
JWT_ACCESS=
JWT_REFRESH=
JWT_ACCESS_MAX_AGE=
JWT_REFRESH_MAX_AGE=

# Database
DB_HOST=
DB_PORT=
DB_PASSWORD=
DB_USERNAME=
DB_DATABASE=

# Google Cloud
GC_KEYPATH=
GC_PROJECT=
GC_BUCKET=

# Payment system
LIQPAY_PUBLIC=
LIQPAY_PRIVATE=

# Monobank online acquiring
# Merchant token from https://web.monobank.ua/ (Acquiring -> API token)
MONOBANK_TOKEN=
# Optional API base URL override (defaults to https://api.monobank.ua)
MONOBANK_API_URL=
# How long an invoice stays payable, in seconds (default 3600)
MONOBANK_INVOICE_VALIDITY=
# Public URL Monobank posts payment status updates to.
# If omitted, it is derived from PUBLIC_API_URL as `${PUBLIC_API_URL}/api/payments/monobank/webhook`.
MONOBANK_WEBHOOK_URL=
# Publicly reachable base URL of this API (used to build the webhook URL)
PUBLIC_API_URL=
# Where customers are redirected after paying (defaults to FRONTEND_URL)
PAYMENT_REDIRECT_URL=


